package day5;
import java.util.Scanner;
public class first_last_digit_sum {
    public static void main(String[] args) {
        Scanner sr = new Scanner(System.in);
        int num = sr.nextInt();
        int last = num % 10;

        while (num >= 10) {
            num = num / 10;

            int first = num;
            System.out.println(first);
            System.out.println(last);
        }
    }
}
