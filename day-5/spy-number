package day5;
import java.util.Scanner;
public class spy_number {
    public static void main(String[] args ){
        Scanner sr=new Scanner(System.in);
        int num=sr.nextInt();
        int sum=0;
        int product=1;

        while (num!= 0) {
            int digit = num % 10;
            sum += digit;
            product += digit;
            num /= 10;
        }

        if (sum==product) {

            System.out.println("it is a spy number");
        }
        else {
            System.out.println("it is not a spy");
        }
    }
}
